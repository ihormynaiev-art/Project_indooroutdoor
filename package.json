{
    "name": "my-playwright-project",
    "version": "1.0.0",
    "description": "Playwright QA automation framework",
    "main": "index.js",
    "scripts": {
        "test": "npx playwright test",
        "test:ui": "npx playwright test --project=chromium tests/ui/",
        "test:api": "npx playwright test tests/api/",
        "test:headed": "npx playwright test --headed",
        "test:debug": "npx playwright test --debug",
        "test:report": "npx playwright show-report",
        "test:dev": "cross-env TEST_ENV=dev npx playwright test",
        "test:stage": "cross-env TEST_ENV=stage npx playwright test",
        "test:prod": "cross-env TEST_ENV=prod npx playwright test",
        "allure:generate": "npx allure generate allure-results --clean",
        "allure:open": "npx allure open allure-report",
        "allure:clear": "npx rimraf allure-results allure-report"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "devDependencies": {
        "@playwright/test": "^1.57.0",
        "@types/node": "^25.0.3",
        "@typescript-eslint/eslint-plugin": "^8.52.0",
        "@typescript-eslint/parser": "^8.52.0",
        "allure-commandline": "^2.32.0",
        "allure-playwright": "^3.0.0-beta.10",
        "cross-env": "^7.0.3",
        "dotenv": "^16.4.5",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-playwright": "^2.4.0",
        "eslint-plugin-prettier": "^5.5.4",
        "prettier": "^3.7.4",
        "rimraf": "^6.0.1"
    }
}
