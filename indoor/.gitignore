# ------------------------------
# Laravel core
# ------------------------------
/vendor/
/node_modules/
/bootstrap/cache/*.php
/storage/app/*
/storage/framework/*
/storage/logs/*
/storage/debugbar/*
/storage/*.key
!storage/app/public/categoryIcons
!storage/app/public/categoryImages
!storage/app/public/logos

# ignore Laravel environment files
.env
.env.backup
.env.production
.env.local
.env.testing
.phpunit.result.cache
/.phpunit.cache

# ignore compiled frontend build files
/public/storage
/public/hot
/public/sitemap.xml
/public/mix-manifest.json
/public/js/*
/public/css/*
!/public/js/.gitkeep
!/public/css/.gitkeep

# ------------------------------
# Docker
# ------------------------------
/docker-compose.override.yml
/.docker/
/.dockerignore

# ------------------------------
# IDE / System
# ------------------------------
.idea/
.vscode/
.DS_Store
/.fleet
Thumbs.db
*.log

# React
/frontend/node_modules
/frontend/build
/frontend/dist
/frontend/.cache
/frontend/.env.local
/frontend/.env.*.local

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

/bootstrap/cache/*
!/bootstrap/cache/.gitignore
=======
# ------------------------------
# React frontend (if using /frontend)
# ------------------------------
/frontend/node_modules/
/frontend/build/
/frontend/dist/
/frontend/.cache/
/frontend/.env.local
/frontend/.env.*.local

# ------------------------------
# Composer / NPM artifacts
# ------------------------------
auth.json
npm-debug.log
yarn-error.log
package-lock.json
pnpm-lock.yaml
/docker/certbot
/docker/mysql
